/* Lesson result page (/learn/lesson/result/:id) — base (light); dark overrides in dark.styl */

.lesson-result {}

.lesson-result__header-wrap
  margin-bottom: 20px

.lesson-result__node-path
  font-size: 14px
  color: #666
  margin-bottom: 8px

.lesson-result__card-heading
  font-size: 24px
  font-weight: bold
  margin: 0

.lesson-result__panel
  margin-bottom: 30px
  border-radius: 8px
  border: 1px solid #e0e0e0
  background-color: #fff

.lesson-result__panel--dense
  padding: 20px

.lesson-result__panel--padded
  padding: 30px

.lesson-result__sheet-title
  font-size: 18px
  margin-bottom: 12px
  margin-top: 0
  color: #333
  font-weight: 600

.lesson-result__sheet-title--lg
  font-size: 20px
  margin-bottom: 20px

.lesson-result__sheet-title--details
  font-size: 16px
  margin-bottom: 16px
  margin-top: 20px

.lesson-result__markdown.typo.richmedia
  font-size: 16px
  line-height: 1.6
  color: #555

.lesson-result__stats-grid
  display: flex
  justify-content: space-around
  margin-bottom: 30px
  padding: 20px
  border-radius: 8px
  background-color: #f5f5f5

.lesson-result__stat
  text-align: center

.lesson-result__stat-value
  font-size: 32px
  font-weight: bold
  margin-bottom: 8px

.lesson-result__stat-value--ok
  color: #4caf50

.lesson-result__stat-value--acc
  color: #2196f3

.lesson-result__stat-value--time
  color: #ff9800

.lesson-result__stat-label
  font-size: 14px
  color: #666

.lesson-result__qrow
  padding: 16px
  margin-bottom: 12px
  border-radius: 6px
  border: 1px solid

.lesson-result__qrow--correct
  background-color: #e8f5e9
  border-color: #4caf50

.lesson-result__qrow--wrong
  background-color: #ffebee
  border-color: #f44336

.lesson-result__qtitle
  font-size: 14px
  font-weight: 500
  margin-bottom: 8px

.lesson-result__qmeta
  font-size: 12px
  color: #666
  margin-bottom: 4px

.lesson-result__qmeta:last-child
  margin-bottom: 0

.lesson-result__footer
  text-align: center
  padding: 20px

.lesson-result__actions
  display: flex
  gap: 12px
  justify-content: center
  flex-wrap: wrap

.lesson-result__actions .button
  padding: 12px 32px
  font-size: 16px
  font-weight: bold
