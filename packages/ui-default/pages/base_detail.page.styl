@import './roadmap_detail_shared.styl'
.page--base_detail
  --roadmap-bg-page: $page-bg-color
  --roadmap-bg-canvas: $page-bg-color
  --roadmap-bg-surface: #fafafa
  --roadmap-bg-elevated: #ffffff
  --roadmap-text-primary: #111111
  --roadmap-text-secondary: #666666
  --roadmap-text-muted: #444444
  --roadmap-text-body: #333333
  --roadmap-border: #ececec
  --roadmap-border-input: #d8d8d8
  --roadmap-border-card: #e8e8e8
  --roadmap-accent: #4135d6
  --roadmap-drawer-shadow: -12px 0 40px rgba(0, 0, 0, 0.14)
  --roadmap-backdrop: rgba(0, 0, 0, 0.42)
  --roadmap-tab-bg: #ffffff
  --roadmap-tab-fg: #444444
  --roadmap-tab-active-bg: #111111
  --roadmap-tab-active-fg: #ffffff
  --roadmap-problem-badge-bg: #4135d6
  background: var(--roadmap-bg-page)
  color: var(--roadmap-text-primary)

  &.hasjs .nav
    position: relative !important
    top: auto
    left: auto

  .nav--shadow
    display: none

  .roadmap-view-page
    position: relative
    top: auto
    left: auto
    right: auto
    bottom: auto
    z-index: auto
    flex: 1
    min-height: 0
    display: flex
    flex-direction: column
    max-width: none
    margin: 0
    padding: 0
    background: var(--roadmap-bg-page)

  #base-detail-viewer
    flex: 1
    min-height: 0
    display: flex
    flex-direction: column
    width: 100%
    background: var(--roadmap-bg-canvas)

  .roadmap-view__empty
    min-height: 320px
    display: flex
    flex-direction: column
    align-items: center
    justify-content: center
    text-align: center
    gap: 12px
    color: var(--roadmap-text-muted)

.page--base_detail .roadmap-detail-layout
  flex: 1
  min-height: 0
  padding: 24px 16px 0
  box-sizing: border-box

.page--base_detail .roadmap-view
  flex: 1
  min-height: 0
  display: flex
  flex-direction: column
  overflow: visible
  background: var(--roadmap-bg-canvas)

.page--base_detail .roadmap-flow--scroll
  flex: none
  min-height: 0
  height: auto
  max-width: none
  margin: 0
  overflow: visible

  .roadmap-sh-node--kind-sub
    width: 260px
    min-width: 260px
    max-width: 260px

  .roadmap-sh-node--hook-link
    display: block
    text-decoration: none
    color: #111111
    cursor: pointer
    transition: background 0.15s ease, box-shadow 0.15s ease, transform 0.12s ease

    &:hover
      background: #5aa8ff
      box-shadow: 0 3px 12px rgba(43, 120, 228, 0.35)

    &:active
      transform: translateY(1px)

  .roadmap-flow__canvas
    min-height: calc(100dvh - rem($nav-item-height))
    width: 100%

    +mobile()
      min-height: 100dvh

  .react-flow__renderer,
  .react-flow__viewport
    overflow: visible

  .react-flow__node
    overflow: visible

.base-detail-roadmap-panel
  flex: 1
  min-height: 0
  display: flex
  flex-direction: column
  width: 100%
  max-width: none
  margin: 0

  +mobile()
    min-height: 0

.page--base_detail .roadmap-detail-drawer--left
  left: 0
  right: auto
  box-shadow: 12px 0 40px rgba(0, 0, 0, 0.14)
  animation: base-detail-drawer-slide-in-left 0.24s ease

  &.is-closing
    animation: base-detail-drawer-slide-out-left 0.24s ease forwards

.page--base_detail .base-detail-tree-backdrop
  pointer-events: auto
  cursor: pointer
  animation: roadmap-detail-fade-in 0.2s ease

  &.is-closing
    animation: base-detail-drawer-fade-out 0.24s ease forwards

.page--base_detail .roadmap-detail-drawer:not(.roadmap-detail-drawer--left)
  &.is-closing
    animation: base-detail-drawer-slide-out-right 0.24s ease forwards

.page--base_detail button.roadmap-detail-backdrop.roadmap-detail-drawer-backdrop
  animation: roadmap-detail-fade-in 0.2s ease

  &.is-closing
    animation: base-detail-drawer-fade-out 0.24s ease forwards

@keyframes base-detail-drawer-slide-in-left
  from
    transform: translateX(-100%)
  to
    transform: translateX(0)

@keyframes base-detail-drawer-slide-out-left
  from
    transform: translateX(0)
  to
    transform: translateX(-100%)

@keyframes base-detail-drawer-slide-out-right
  from
    transform: translateX(0)
  to
    transform: translateX(100%)

@keyframes base-detail-drawer-fade-out
  from
    opacity: 1
  to
    opacity: 0

.base-detail-main
  flex: 1
  min-width: 0
  min-height: 0
  display: flex
  flex-direction: column
  width: calc(100% - 320px)
  max-width: calc(1100px - 320px)
  margin: 0 auto
  background: var(--roadmap-bg-canvas)
  box-sizing: border-box

  +mobile()
    width: calc(100% - 32px)
    max-width: calc(1100px - 32px)

.base-detail-main__placeholder
  flex: 1
  display: flex
  align-items: center
  justify-content: center
  padding: 48px 24px
  color: var(--roadmap-text-secondary)
  font-size: 14px
  text-align: center

.base-detail-tree
  display: block

.base-detail-tree__branch
  display: block

.base-detail-tree__children
  display: block

.base-detail-tree__row
  display: flex
  align-items: center
  gap: 6px
  min-height: 34px
  padding-right: 8px
  color: var(--roadmap-text-primary)
  font-size: 13px
  line-height: 1.3
  max-width: 100%
  box-sizing: border-box
  border-radius: 6px

  &--node
    font-weight: 600

    &.is-selected
      background: rgba(65, 53, 214, 0.1)

      .base-detail-tree__label
        color: var(--roadmap-accent)

    &:hover:not(.is-selected):not(.is-static)
      background: rgba(65, 53, 214, 0.06)

    &.is-static
      cursor: default

  &--card
    font-weight: 400
    color: var(--roadmap-text-secondary)

    &.is-selected
      background: rgba(65, 53, 214, 0.1)

      .base-detail-tree__label
        color: var(--roadmap-accent)

    &:hover:not(.is-selected)
      background: rgba(65, 53, 214, 0.06)

  &--problem
    font-weight: 400
    color: var(--roadmap-text-secondary)
    font-size: 12px
    min-height: 28px

    &.is-selected
      background: rgba(255, 210, 74, 0.2)
      color: var(--roadmap-text-primary)

    &:hover:not(.is-selected)
      background: rgba(65, 53, 214, 0.04)

  &.is-roadmap
    .base-detail-tree__label
      color: var(--roadmap-accent)

.base-detail-tree__row-main
  display: inline-flex
  align-items: center
  gap: 6px
  flex: 1
  min-width: 0
  padding: 0
  border: 0
  background: transparent
  text-align: left
  cursor: pointer
  font-family: inherit
  font-size: inherit
  font-weight: inherit
  color: inherit

  &--static
    cursor: default
    pointer-events: none

.base-detail-tree__toggle
  display: inline-flex
  align-items: center
  justify-content: center
  width: 18px
  height: 18px
  padding: 0
  border: 0
  background: transparent
  color: var(--roadmap-text-muted)
  cursor: pointer
  flex-shrink: 0

  &:hover
    color: var(--roadmap-text-primary)

.base-detail-tree__toggle-spacer
  width: 18px
  flex-shrink: 0

.base-detail-tree__chevron
  transition: transform 0.15s ease

  &.is-expanded
    transform: rotate(90deg)

.base-detail-tree__icon
  display: inline-flex
  align-items: center
  justify-content: center
  flex-shrink: 0
  color: var(--roadmap-text-muted)

.base-detail-tree__label
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  flex: 1
  min-width: 0

.base-detail-tree__label-wrap
  display: flex
  flex-direction: row
  align-items: center
  gap: 8px
  flex: 1
  min-width: 0
  overflow: hidden

.base-detail-tree__meta
  flex-shrink: 0
  max-width: 45%
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  font-size: 11px
  font-weight: 400
  color: var(--roadmap-text-muted)
  line-height: 1.35
  opacity: 0.85
  text-align: right

.base-detail-tree__problem-badge
  flex-shrink: 0
  min-width: 18px
  height: 18px
  padding: 0 5px
  border-radius: 999px
  background: var(--roadmap-problem-badge-bg)
  color: #fff
  font-size: 11px
  font-weight: 700
  line-height: 18px
  text-align: center

.base-detail-tree__card-tags
  display: inline-flex
  align-items: center
  gap: 4px
  flex-wrap: wrap

.base-detail-tree__tag
  display: inline-block
  padding: 1px 6px
  border-radius: 4px
  background: var(--roadmap-tag-bg, rgba(65, 53, 214, 0.1))
  color: var(--roadmap-tag-color, var(--roadmap-accent, #4135d6))
  font-size: 10px
  font-weight: 500
  line-height: 1.4
  white-space: nowrap

.base-detail-tree__problem-tags
  display: inline-flex
  align-items: center
  gap: 3px
  flex-wrap: wrap
  margin-left: 4px

.base-detail-tree__tag--problem
  display: inline-block
  padding: 2px 7px
  border-radius: 3px
  background: rgba(255, 152, 0, 0.12)
  border: 1px solid rgba(255, 152, 0, 0.35)
  color: #bf360c
  font-size: 10px
  font-weight: 600
  line-height: 1.3
  white-space: nowrap

.base-detail-main--node
  padding: 0 0 32px

.base-detail-node-tree
  padding: 16px 0 24px
  width: 100%
  max-width: 100%
  overflow: hidden

.page--base_detail #editor-container
  .roadmap-node-markdown-editor
    flex: 1
    min-height: 0
    height: 100%
    overflow: hidden
    position: relative
    display: flex
    flex-direction: column

    .roadmap-node-markdown-editor__textarea
      width: 100%
      height: 100%
      border: 0
      resize: none

    .textbox,
    .md-editor
      flex: 1
      height: 100% !important
      min-height: 0 !important

    .md-editor-preview
      roadmap-text-btn-styles()

.theme--dark.page--base_detail
  --roadmap-bg-page: #1e1e1e
  --roadmap-bg-canvas: #1e1e1e
  --roadmap-bg-surface: #252526
  --roadmap-bg-elevated: #2d2d2d
  --roadmap-text-primary: #e8e8e8
  --roadmap-text-secondary: #bdbdbd
  --roadmap-text-muted: #888888
  --roadmap-text-body: #cccccc
  --roadmap-border: #3c3c3c
  --roadmap-border-card: #404040
  --roadmap-border-input: #4a4a4a
  --roadmap-accent: #9d93f0
  --roadmap-accent-blue: #8ec5ff
  --roadmap-edge: #6eb3ff
  --roadmap-edge-hover: #8ec5ff
  --roadmap-node-border: #9d93f0
  --roadmap-node-text: #eeeeee
  --roadmap-node-bg-planned: #5c4a1a
  --roadmap-node-bg-done: #4a4a4a
  --roadmap-node-bg-in_progress: #4a3d6b
  --roadmap-node-bg-blocked: #6b2f2f
  --roadmap-handle-border: #252526
  --roadmap-handle-bg: #6eb3ff
  --roadmap-drawer-shadow: -12px 0 40px rgba(0, 0, 0, 0.45)
  --roadmap-backdrop: rgba(0, 0, 0, 0.58)
  --roadmap-tab-bg: #323334
  --roadmap-tab-fg: #cccccc
  --roadmap-tab-active-bg: #eeeeee
  --roadmap-tab-active-fg: #121212
  --roadmap-badge-bg: #4a3f1a
  --roadmap-badge-fg: #f0d878
  --roadmap-problem-badge-bg: #9d93f0
  --roadmap-problem-badge-shadow: rgba(157, 147, 240, 0.42)
  --roadmap-lane-border: rgba(157, 147, 240, 0.5)
  --roadmap-lane-fill: rgba(157, 147, 240, 0.14)
  --roadmap-lane-fill-end: rgba(157, 147, 240, 0.06)
  --roadmap-lane-label-bg: rgba(37, 37, 38, 0.94)
  --roadmap-lane-label-border: rgba(157, 147, 240, 0.35)
