.page--roadmap_detail,
.page--roadmap_edit
  background: #ffffff

.page--roadmap_detail
  .roadmap-view-page
    max-width: 100%
    margin: 0 auto
    padding: 24px 16px 64px

  .roadmap-view-page__header
    display: flex
    align-items: flex-start
    justify-content: space-between
    gap: 16px
    margin-bottom: 20px

  .roadmap-view-page__title
    margin: 0
    font-size: 32px
    line-height: 1.1
    letter-spacing: -0.04em
    color: #111111

  .roadmap-view-page__branch
    margin: 8px 0 0
    color: #666666
    font-size: 13px

  .roadmap-view-page__actions
    flex-shrink: 0

  .roadmap-view__empty
    min-height: 320px
    display: flex
    flex-direction: column
    align-items: center
    justify-content: center
    text-align: center
    gap: 12px
    color: #444444

.page--roadmap_edit
  .roadmap-shell
    background: #ffffff
    border: 1px solid #e8e8e8
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06)
    overflow: hidden

  .roadmap-shell__header
    color: #111111
    border-bottom: 1px solid #ececec
    background: #fafafa

  .roadmap-title
    color: #111111
    letter-spacing: -0.04em

  .roadmap-kicker
    text-transform: uppercase
    letter-spacing: 0.18em
    font-size: 11px
    color: #666666
    margin-bottom: 6px

  .roadmap-actions
    display: flex
    gap: 8px
    align-items: center

  .roadmap-shell__body
    background: #ffffff

.roadmap-view
  width: 100%

.roadmap-flow--scroll
  width: 100%
  max-width: 1100px
  margin: 0 auto
  background: #ffffff
  overflow: visible

  .react-flow
    background: transparent

  .react-flow__renderer,
  .react-flow__viewport
    overflow: visible

  .react-flow__edge.selected .react-flow__edge-path,
  .react-flow__edge:hover .react-flow__edge-path
    stroke: #1a5fb4 !important
    stroke-width: 4 !important

  .react-flow__edge
    cursor: pointer

.roadmap-flow__canvas
  width: 100%

  .react-flow
    width: 100%
    height: 100%

.roadmap-flow--editor
  height: min(72vh, 720px)
  min-height: 480px
  border: 1px solid #e8e8e8
  border-radius: 12px
  overflow: hidden

  .roadmap-flow__canvas
    height: 100%

.roadmap-lane-overlay
  position: absolute
  top: 0
  left: 0
  pointer-events: none
  z-index: 1
  overflow: hidden

.roadmap-lane-overlay__world
  position: absolute
  top: 0
  left: 0
  transform-origin: 0 0

.roadmap-lane-guide
  position: absolute
  top: 0
  pointer-events: none
  border-left: 1px dashed rgba(65, 53, 214, 0.22)
  border-right: 1px dashed rgba(65, 53, 214, 0.22)
  background: linear-gradient(180deg, rgba(65, 53, 214, 0.05) 0%, rgba(65, 53, 214, 0.02) 100%)
  border-radius: 12px
  box-sizing: border-box

.roadmap-lane-guide__label
  position: absolute
  top: 12px
  left: 50%
  transform: translateX(-50%)
  width: 28px
  height: 28px
  border-radius: 999px
  display: flex
  align-items: center
  justify-content: center
  font-size: 13px
  font-weight: 700
  color: #4135d6
  background: rgba(255, 255, 255, 0.92)
  border: 1px solid rgba(65, 53, 214, 0.28)
  box-shadow: 0 2px 8px rgba(65, 53, 214, 0.08)

.roadmap-sh-node
  min-width: 132px
  max-width: 260px
  padding: 10px 16px
  border: 2px solid #4135d6
  border-radius: 8px
  background: #ffe599
  color: #111111
  text-align: center
  box-shadow: none
  cursor: default

  &.is-selected
    box-shadow: 0 0 0 3px rgba(65, 53, 214, 0.28)

.roadmap-sh-node--done
  background: #cbcbcb

.roadmap-sh-node--in_progress
  background: #dad1fd

.roadmap-sh-node--blocked
  background: #ffcfcf

.roadmap-sh-node__title
  font-size: 15px
  font-weight: 500
  line-height: 1.35
  word-break: break-word

.roadmap-sh-node__handle
  width: 10px
  height: 10px
  border: 2px solid #ffffff
  background: #2b78e4

.page--roadmap_edit .roadmap-sh-node
  cursor: grab

.page--roadmap_detail .roadmap-sh-node__handle
  visibility: hidden
  width: 1px
  height: 1px
  min-width: 0
  min-height: 0
  border: 0
  opacity: 0

.roadmap-empty
  color: #444444
  min-height: 420px
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  text-align: center
  gap: 12px

.roadmap-empty__mark
  width: 76px
  height: 76px
  border: 1px solid #d8d8d8
  border-radius: 50%
  display: flex
  align-items: center
  justify-content: center
  color: #4135d6
  font-size: 42px

.roadmap-editor-layout
  color: #111111
  position: relative

.roadmap-toolbar
  min-height: 96px
  display: flex
  align-items: center
  justify-content: space-between
  gap: 18px
  padding: 20px 24px
  border-bottom: 1px solid #ececec
  background: #fafafa

.roadmap-hero__eyebrow
  text-transform: uppercase
  letter-spacing: 0.2em
  font-size: 11px
  color: #666666
  margin-bottom: 6px

.roadmap-toolbar__title
  font-size: 28px
  line-height: 1.1
  letter-spacing: -0.04em
  color: #111111

.roadmap-toolbar__actions
  display: flex
  flex-wrap: wrap
  align-items: center
  justify-content: flex-end
  gap: 8px

.roadmap-editor-grid
  display: grid
  grid-template-columns: minmax(0, 1fr) 330px

.roadmap-tool-button
  border: 1px solid #d8d8d8
  border-radius: 999px
  background: #ffffff
  color: #333333
  padding: 8px 12px
  cursor: pointer
  transition: 0.18s ease

  &:hover:not(:disabled)
    border-color: #4135d6
    color: #4135d6
    transform: translateY(-1px)

  &:disabled
    opacity: 0.45
    cursor: not-allowed

.roadmap-tool-button--danger
  border-color: #f0b4b4
  color: #c0392b

.roadmap-tool-button--save
  border-color: #8fd6a3
  color: #1f7a3f

.roadmap-inspector
  border-left: 1px solid #ececec
  padding: 22px
  background: #fafafa
  color: #111111

  label
    display: block
    margin-bottom: 14px
    color: #555555
    font-size: 12px
    letter-spacing: 0.04em

  input,
  select,
  textarea
    display: block
    width: 100%
    margin-top: 6px
    border-radius: 10px
    border: 1px solid #d8d8d8
    background: #ffffff
    color: #111111
    padding: 9px 10px

  textarea
    resize: vertical

  p
    color: #666666
    font-size: 12px

.roadmap-inspector__kicker
  color: #4135d6
  text-transform: uppercase
  letter-spacing: 0.18em
  font-size: 11px
  margin-bottom: 18px

.roadmap-inspector__empty
  color: #666666
  line-height: 1.6

@media (max-width: 900px)
  .roadmap-editor-grid
    grid-template-columns: 1fr

  .roadmap-inspector
    border-left: 0
    border-top: 1px solid #ececec

  .roadmap-toolbar
    align-items: flex-start
    flex-direction: column
