.page--roadmap_detail,
.page--roadmap_edit
  --roadmap-bg-page: #ffffff
  --roadmap-bg-canvas: #ffffff
  --roadmap-bg-surface: #fafafa
  --roadmap-bg-elevated: #ffffff
  --roadmap-text-primary: #111111
  --roadmap-text-secondary: #666666
  --roadmap-text-muted: #444444
  --roadmap-text-body: #333333
  --roadmap-border: #ececec
  --roadmap-border-input: #d8d8d8
  --roadmap-border-card: #e8e8e8
  --roadmap-accent: #4135d6
  --roadmap-accent-blue: #1a5fb4
  --roadmap-edge: #2b78e4
  --roadmap-edge-hover: #1a5fb4
  --roadmap-node-border: #4135d6
  --roadmap-node-text: #111111
  --roadmap-node-bg-planned: #ffe599
  --roadmap-node-bg-done: #cbcbcb
  --roadmap-node-bg-in_progress: #dad1fd
  --roadmap-node-bg-blocked: #ffcfcf
  --roadmap-handle-border: #ffffff
  --roadmap-handle-bg: #2b78e4
  --roadmap-drawer-shadow: -12px 0 40px rgba(0, 0, 0, 0.14)
  --roadmap-backdrop: rgba(0, 0, 0, 0.42)
  --roadmap-tab-bg: #ffffff
  --roadmap-tab-fg: #444444
  --roadmap-tab-active-bg: #111111
  --roadmap-tab-active-fg: #ffffff
  --roadmap-badge-bg: #fff3cd
  --roadmap-badge-fg: #7a5b00
  --roadmap-lane-border: rgba(65, 53, 214, 0.22)
  --roadmap-lane-fill: rgba(65, 53, 214, 0.05)
  --roadmap-lane-fill-end: rgba(65, 53, 214, 0.02)
  --roadmap-lane-label-bg: rgba(255, 255, 255, 0.92)
  --roadmap-lane-label-border: rgba(65, 53, 214, 0.28)
  background: var(--roadmap-bg-page)
  color: var(--roadmap-text-primary)

.page--roadmap_detail
  .roadmap-view-page
    position: fixed
    top: rem($nav-item-height)
    left: 0
    right: 0
    bottom: 0
    z-index: 1
    flex: 1
    min-height: 0
    display: flex
    flex-direction: column
    max-width: none
    margin: 0
    padding: 0
    background: var(--roadmap-bg-page)

    +mobile()
      top: 0

  #roadmap-viewer
    flex: 1
    min-height: 0
    display: flex
    flex-direction: column
    width: 100%
    background: var(--roadmap-bg-canvas)

  .roadmap-view__empty
    min-height: 320px
    display: flex
    flex-direction: column
    align-items: center
    justify-content: center
    text-align: center
    gap: 12px
    color: var(--roadmap-text-muted)

.page--roadmap_edit
  .roadmap-shell
    background: #ffffff
    border: 1px solid #e8e8e8
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06)
    overflow: hidden

  .roadmap-shell__header
    color: #111111
    border-bottom: 1px solid #ececec
    background: #fafafa

  .roadmap-title
    color: #111111
    letter-spacing: -0.04em

  .roadmap-kicker
    text-transform: uppercase
    letter-spacing: 0.18em
    font-size: 11px
    color: #666666
    margin-bottom: 6px

  .roadmap-actions
    display: flex
    gap: 8px
    align-items: center

  .roadmap-shell__body
    background: #ffffff
    flex: 1
    min-height: 0
    display: flex
    flex-direction: column

  .roadmap-shell--editor
    display: flex
    flex-direction: column
    min-height: calc(100vh - 180px)

  #roadmap-editor
    flex: 1
    min-height: 0
    display: flex
    flex-direction: column

.roadmap-view
  width: 100%

.roadmap-flow--scroll
  width: 100%
  max-width: 1100px
  margin: 0 auto
  background: var(--roadmap-bg-canvas)
  overflow: visible

  .react-flow
    background: transparent

  .react-flow__renderer,
  .react-flow__viewport
    overflow: visible

  .react-flow__edge.selected .react-flow__edge-path,
  .react-flow__edge:hover .react-flow__edge-path
    stroke: var(--roadmap-edge-hover) !important
    stroke-width: 4 !important

  .react-flow__edge
    cursor: pointer

.page--roadmap_detail .roadmap-flow--scroll
  flex: 1
  min-height: 0
  height: 100%
  max-width: none
  margin: 0
  overflow-x: hidden
  overflow-y: auto
  -webkit-overflow-scrolling: touch

  .roadmap-flow__canvas
    min-height: 100%
    width: 100%
    position: relative

  .roadmap-lane-background
    position: absolute
    inset: 0
    pointer-events: none
    z-index: 0
    overflow: hidden

  .react-flow
    position: relative
    z-index: 1
    background: transparent !important

  .react-flow__pane
    background: transparent !important

  .react-flow__renderer,
  .react-flow__viewport
    overflow: visible

.roadmap-flow__canvas
  width: 100%
  position: relative

  .react-flow
    width: 100%
    height: 100%

.roadmap-flow--editor,
.roadmap-flow--workspace
  flex: 1
  min-height: 0
  height: 100%
  border: 0
  border-radius: 0
  overflow: hidden

  .roadmap-flow__canvas
    height: 100%

  .react-flow__edge.selected .react-flow__edge-path,
  .react-flow__edge:hover .react-flow__edge-path
    stroke: var(--roadmap-edge-hover) !important
    stroke-width: 4 !important

  .react-flow__edge
    cursor: pointer

  .react-flow__node.selected .roadmap-sh-node,
  .roadmap-sh-node.is-selected
    border-color: #1a5fb4
    box-shadow: 0 0 0 3px rgba(26, 95, 180, 0.35)

.editor-workspace-shell
  .roadmap-node-markdown-editor
    flex: 1
    min-height: 0
    height: 100%
    overflow: hidden
    position: relative

    .roadmap-node-markdown-editor__textarea
      width: 100%
      height: 100%
      border: 0
      resize: none

    .textbox,
    .md-editor
      height: 100% !important
      min-height: 0 !important

.roadmap-inspector--workspace
  flex: 1
  min-height: 0
  overflow-y: auto
  padding: 16px 18px

.roadmap-lane-overlay
  position: absolute
  top: 0
  left: 0
  pointer-events: none
  z-index: 1
  overflow: hidden

.roadmap-lane-overlay__world
  position: absolute
  top: 0
  left: 0
  transform-origin: 0 0

.roadmap-lane-guide
  position: absolute
  top: 0
  pointer-events: none
  border-left: 1px dashed var(--roadmap-lane-border)
  border-right: 1px dashed var(--roadmap-lane-border)
  background: linear-gradient(180deg, var(--roadmap-lane-fill) 0%, var(--roadmap-lane-fill-end) 100%)
  border-radius: 12px
  box-sizing: border-box

.roadmap-lane-guide__label
  position: absolute
  top: 12px
  left: 50%
  transform: translateX(-50%)
  width: 28px
  height: 28px
  border-radius: 999px
  display: flex
  align-items: center
  justify-content: center
  font-size: 13px
  font-weight: 700
  color: var(--roadmap-accent)
  background: var(--roadmap-lane-label-bg)
  border: 1px solid var(--roadmap-lane-label-border)
  box-shadow: 0 2px 8px rgba(65, 53, 214, 0.08)

.roadmap-sh-node
  width: 260px
  min-width: 260px
  max-width: 260px
  box-sizing: border-box
  padding: 10px 16px
  border: 2px solid var(--roadmap-node-border)
  border-radius: 8px
  background: var(--roadmap-node-bg-planned)
  color: var(--roadmap-node-text)
  text-align: center
  box-shadow: none
  cursor: default

  &.is-selected
    border-color: var(--roadmap-accent-blue)
    box-shadow: 0 0 0 3px rgba(26, 95, 180, 0.35)

.roadmap-sh-node--done
  background: var(--roadmap-node-bg-done)

.roadmap-sh-node--in_progress
  background: var(--roadmap-node-bg-in_progress)

.roadmap-sh-node--blocked
  background: var(--roadmap-node-bg-blocked)

.roadmap-sh-node--pending-create
  border-color: #4caf50
  border-style: dashed
  background: rgba(76, 175, 80, 0.08)

.roadmap-sh-node--pending-update
  border-color: #ff9800
  border-style: dashed
  background: rgba(255, 152, 0, 0.08)

.roadmap-sh-node--pending-delete,
.roadmap-sh-node--pending-ghost
  border-color: #f44336
  border-style: dashed
  background: rgba(244, 67, 54, 0.08)
  opacity: 0.72

.roadmap-sh-node--pending-create.is-selected
  box-shadow: 0 0 0 3px rgba(76, 175, 80, 0.28)

.roadmap-sh-node--pending-update.is-selected
  box-shadow: 0 0 0 3px rgba(255, 152, 0, 0.28)

.roadmap-sh-node--pending-delete.is-selected,
.roadmap-sh-node--pending-ghost.is-selected
  box-shadow: 0 0 0 3px rgba(244, 67, 54, 0.28)

.roadmap-sh-node__title
  font-size: 15px
  font-weight: 500
  line-height: 1.35
  word-break: break-word

.roadmap-sh-node__handle
  width: 10px
  height: 10px
  border: 2px solid var(--roadmap-handle-border)
  background: var(--roadmap-handle-bg)

.page--roadmap_edit .roadmap-sh-node
  cursor: grab

.page--roadmap_detail .roadmap-sh-node__handle
  visibility: hidden
  width: 1px
  height: 1px
  min-width: 0
  min-height: 0
  border: 0
  opacity: 0

.roadmap-empty
  color: #444444
  min-height: 420px
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  text-align: center
  gap: 12px

.roadmap-empty__mark
  width: 76px
  height: 76px
  border: 1px solid #d8d8d8
  border-radius: 50%
  display: flex
  align-items: center
  justify-content: center
  color: #4135d6
  font-size: 42px

.roadmap-editor-layout
  color: #111111
  position: relative
  display: flex
  flex-direction: column
  flex: 1
  min-height: 0
  height: 100%

.roadmap-editor-body
  display: flex
  flex: 1
  min-height: 0
  overflow: hidden
  align-items: stretch

.roadmap-canvas-panel
  width: 360px
  flex-shrink: 0
  border-right: 1px solid #ececec
  background: #fafafa
  display: flex
  flex-direction: column
  min-height: 0
  min-width: 0

.roadmap-editor-main
  flex: 1
  min-width: 0
  min-height: 0
  display: flex
  flex-direction: column
  overflow: hidden
  background: #ffffff

.roadmap-editor-main__header
  flex-shrink: 0
  padding: 8px 16px
  border-bottom: 1px solid #ececec
  background: #ffffff

.roadmap-editor-main__title-field
  display: block
  margin: 0
  color: #555555
  font-size: 12px
  letter-spacing: 0.04em

  input
    display: block
    width: 100%
    margin-top: 6px
    border-radius: 8px
    border: 1px solid #d8d8d8
    background: #ffffff
    color: #111111
    padding: 8px 10px
    font-size: 14px

.roadmap-side-panel
  display: flex
  flex-direction: column
  min-height: 0

.roadmap-side-panel--edge
  width: 320px
  flex-shrink: 0
  border-left: 1px solid #ececec
  background: #fafafa
  overflow-y: auto
  min-height: 0

.roadmap-toolbar
  min-height: 96px
  display: flex
  align-items: center
  justify-content: space-between
  gap: 18px
  padding: 20px 24px
  border-bottom: 1px solid #ececec
  background: #fafafa

.roadmap-hero__eyebrow
  text-transform: uppercase
  letter-spacing: 0.2em
  font-size: 11px
  color: #666666
  margin-bottom: 6px

.roadmap-toolbar__title
  font-size: 28px
  line-height: 1.1
  letter-spacing: -0.04em
  color: #111111

.roadmap-toolbar__actions
  display: flex
  flex-wrap: wrap
  align-items: center
  justify-content: flex-end
  gap: 8px

.roadmap-node-markdown-editor
  flex: 1
  min-height: 0
  overflow: hidden
  position: relative

  .roadmap-node-markdown-editor__textarea
    width: 100%
    height: 100%
    border: 0
    resize: none

  .textbox,
  .md-editor
    height: 100% !important
    min-height: 0 !important

.roadmap-detail-layout
  display: flex
  flex-direction: column
  flex: 1
  min-height: 0
  height: 100%
  overflow: hidden
  position: relative

.page--roadmap_detail .roadmap-view
  flex: 1
  min-height: 0
  height: 100%
  display: flex
  flex-direction: column
  overflow: hidden

.roadmap-detail-backdrop
  position: fixed
  top: rem($nav-item-height)
  right: 0
  bottom: 0
  left: 0
  border: 0
  padding: 0
  margin: 0
  background: var(--roadmap-backdrop)
  z-index: 120
  pointer-events: none
  animation: roadmap-detail-fade-in 0.2s ease

  +mobile()
    top: 0

.roadmap-detail-drawer
  position: fixed
  top: rem($nav-item-height)
  right: 0
  bottom: 0
  width: min(420px, 36vw)
  max-width: 100%
  z-index: 130
  pointer-events: auto
  background: var(--roadmap-bg-elevated)
  color: var(--roadmap-text-primary)
  box-shadow: var(--roadmap-drawer-shadow)
  display: flex
  flex-direction: column
  animation: roadmap-detail-slide-in 0.24s ease

  +mobile()
    top: 0
    width: min(100%, 420px)

.roadmap-detail-drawer__header
  display: flex
  align-items: center
  justify-content: space-between
  gap: 12px
  padding: 14px 16px
  border-bottom: 1px solid var(--roadmap-border)
  background: var(--roadmap-bg-surface)
  flex-shrink: 0

.roadmap-detail-drawer__tabs
  display: flex
  align-items: center
  gap: 6px

.roadmap-detail-drawer__tab
  border: 1px solid var(--roadmap-border-input)
  background: var(--roadmap-tab-bg)
  color: var(--roadmap-tab-fg)
  border-radius: 999px
  padding: 6px 14px
  font-size: 12px
  font-weight: 600
  cursor: pointer
  line-height: 1.2

  &.is-active
    background: var(--roadmap-tab-active-bg)
    border-color: var(--roadmap-tab-active-bg)
    color: var(--roadmap-tab-active-fg)

.roadmap-detail-drawer__header-actions
  display: flex
  align-items: center
  gap: 10px
  flex-shrink: 0

.roadmap-detail-drawer__status
  display: inline-flex
  align-items: center
  gap: 6px
  padding: 5px 10px
  border-radius: 999px
  border: 1px solid var(--roadmap-border-card)
  background: var(--roadmap-bg-elevated)
  font-size: 12px
  color: var(--roadmap-text-body)
  white-space: nowrap

.roadmap-detail-drawer__status-dot
  width: 8px
  height: 8px
  border-radius: 50%
  background: var(--roadmap-status-color, #78c7d2)
  flex-shrink: 0

.roadmap-detail-drawer__close
  border: 0
  background: transparent
  color: var(--roadmap-text-secondary)
  font-size: 26px
  line-height: 1
  cursor: pointer
  padding: 0 2px

.roadmap-detail-drawer__body
  flex: 1
  min-height: 0
  overflow-y: auto
  padding: 22px 22px 28px
  -webkit-overflow-scrolling: touch

.roadmap-detail-drawer__title
  margin: 0 0 14px
  font-size: 28px
  line-height: 1.15
  letter-spacing: -0.03em
  color: var(--roadmap-text-primary)

.roadmap-detail-drawer__markdown
  color: var(--roadmap-text-body)
  font-size: 14px
  line-height: 1.65
  margin-bottom: 24px

.roadmap-detail-drawer__section
  margin-top: 8px
  padding-top: 18px
  border-top: 1px solid var(--roadmap-border)

.roadmap-detail-drawer__section-title
  margin: 0 0 12px
  font-size: 13px
  font-weight: 700
  letter-spacing: 0.06em
  text-transform: uppercase
  color: var(--roadmap-text-secondary)

.roadmap-detail-drawer__resource-list
  list-style: none
  margin: 0
  padding: 0
  display: flex
  flex-direction: column
  gap: 10px

.roadmap-detail-drawer__resource-item
  display: flex
  align-items: flex-start
  gap: 10px
  padding: 12px 14px
  border: 1px solid var(--roadmap-border-card)
  border-radius: 10px
  background: var(--roadmap-bg-surface)

.roadmap-detail-drawer__resource-badge
  flex-shrink: 0
  padding: 3px 8px
  border-radius: 6px
  background: var(--roadmap-badge-bg)
  color: var(--roadmap-badge-fg)
  font-size: 11px
  font-weight: 600
  line-height: 1.3

.roadmap-detail-drawer__resource-label
  flex: 1
  min-width: 0
  font-size: 14px
  line-height: 1.45
  color: var(--roadmap-text-primary)

@keyframes roadmap-detail-fade-in
  from
    opacity: 0
  to
    opacity: 1

@keyframes roadmap-detail-slide-in
  from
    transform: translateX(100%)
  to
    transform: translateX(0)

.roadmap-node-markdown-preview
  padding: 18px

.roadmap-node-markdown-preview__title
  margin: 0 0 14px
  font-size: 22px
  line-height: 1.2
  color: #111111

.roadmap-node-markdown-preview__body
  color: #222222
  padding: 0 18px

.roadmap-node-markdown-preview--empty,
.roadmap-node-markdown-preview--loading,
.roadmap-node-markdown-preview--error
  padding: 24px 18px
  color: #666666
  text-align: center

.page--roadmap_detail .roadmap-sh-node
  cursor: pointer

.roadmap-tool-button
  border: 1px solid #d8d8d8
  border-radius: 999px
  background: #ffffff
  color: #333333
  padding: 8px 12px
  cursor: pointer
  transition: 0.18s ease

  &:hover:not(:disabled)
    border-color: #4135d6
    color: #4135d6
    transform: translateY(-1px)

  &:disabled
    opacity: 0.45
    cursor: not-allowed

.roadmap-tool-button--danger
  border-color: #f0b4b4
  color: #c0392b

.roadmap-tool-button--save
  border-color: #8fd6a3
  color: #1f7a3f

.roadmap-inspector
  padding: 22px
  color: #111111

  label
    display: block
    margin-bottom: 14px
    color: #555555
    font-size: 12px
    letter-spacing: 0.04em

  input,
  select,
  textarea
    display: block
    width: 100%
    margin-top: 6px
    border-radius: 10px
    border: 1px solid #d8d8d8
    background: #ffffff
    color: #111111
    padding: 9px 10px

  textarea
    resize: vertical

  p
    color: #666666
    font-size: 12px

.roadmap-inspector__kicker
  color: #4135d6
  text-transform: uppercase
  letter-spacing: 0.18em
  font-size: 11px
  margin-bottom: 18px

.roadmap-inspector__empty
  color: var(--roadmap-text-secondary)
  line-height: 1.6

.theme--dark.page--roadmap_detail,
.theme--dark.page--roadmap_edit
  --roadmap-bg-page: #121212
  --roadmap-bg-canvas: #121212
  --roadmap-bg-surface: #1e1e1e
  --roadmap-bg-elevated: #252526
  --roadmap-text-primary: #eeeeee
  --roadmap-text-secondary: #bdbdbd
  --roadmap-text-muted: #999999
  --roadmap-text-body: #cccccc
  --roadmap-border: #3c3c3c
  --roadmap-border-input: #555555
  --roadmap-border-card: #424242
  --roadmap-accent: #9d93f0
  --roadmap-accent-blue: #8ec5ff
  --roadmap-edge: #6eb3ff
  --roadmap-edge-hover: #8ec5ff
  --roadmap-node-border: #9d93f0
  --roadmap-node-text: #eeeeee
  --roadmap-node-bg-planned: #5c4a1a
  --roadmap-node-bg-done: #4a4a4a
  --roadmap-node-bg-in_progress: #4a3d6b
  --roadmap-node-bg-blocked: #6b2f2f
  --roadmap-handle-border: #252526
  --roadmap-handle-bg: #6eb3ff
  --roadmap-drawer-shadow: -12px 0 40px rgba(0, 0, 0, 0.45)
  --roadmap-backdrop: rgba(0, 0, 0, 0.58)
  --roadmap-tab-bg: #323334
  --roadmap-tab-fg: #cccccc
  --roadmap-tab-active-bg: #eeeeee
  --roadmap-tab-active-fg: #121212
  --roadmap-badge-bg: #4a3f1a
  --roadmap-badge-fg: #f0d878
  --roadmap-lane-border: rgba(157, 147, 240, 0.5)
  --roadmap-lane-fill: rgba(157, 147, 240, 0.14)
  --roadmap-lane-fill-end: rgba(157, 147, 240, 0.06)
  --roadmap-lane-label-bg: rgba(37, 37, 38, 0.94)
  --roadmap-lane-label-border: rgba(157, 147, 240, 0.35)

.theme--dark.page--roadmap_edit
  .roadmap-shell
    background: var(--roadmap-bg-elevated)
    border-color: var(--roadmap-border-card)
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35)

  .roadmap-shell__header
    color: var(--roadmap-text-primary)
    border-bottom-color: var(--roadmap-border)
    background: var(--roadmap-bg-surface)

  .roadmap-title
    color: var(--roadmap-text-primary)

  .roadmap-kicker
    color: var(--roadmap-text-secondary)

  .roadmap-shell__body,
  .roadmap-editor-main,
  .roadmap-editor-main__header
    background: var(--roadmap-bg-page)

  .roadmap-canvas-panel,
  .roadmap-side-panel--edge
    background: var(--roadmap-bg-surface)
    border-color: var(--roadmap-border)

  .roadmap-editor-main__header
    border-bottom-color: var(--roadmap-border)

  .roadmap-editor-main__title-field
    color: var(--roadmap-text-secondary)

    input
      border-color: var(--roadmap-border-input)
      background: var(--roadmap-bg-elevated)
      color: var(--roadmap-text-primary)

.theme--dark.page--roadmap_detail,
.theme--dark.page--roadmap_edit
  .roadmap-inspector
    color: var(--roadmap-text-primary)

    label
      color: var(--roadmap-text-secondary)

    input,
    select,
    textarea
      border-color: var(--roadmap-border-input)
      background: var(--roadmap-bg-elevated)
      color: var(--roadmap-text-primary)

    p
      color: var(--roadmap-text-secondary)

  .roadmap-inspector__kicker
    color: var(--roadmap-accent)

  .roadmap-tool-button
    border-color: var(--roadmap-border-input)
    background: var(--roadmap-bg-elevated)
    color: var(--roadmap-text-body)

    &:hover:not(:disabled)
      border-color: var(--roadmap-accent)
      color: var(--roadmap-accent)

  .roadmap-flow__canvas .react-flow
    background: var(--roadmap-bg-canvas)

  .react-flow__pane
    background: transparent

  .roadmap-lane-guide__label
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35)

  .react-flow__controls
    box-shadow: 0 0 0 1px var(--roadmap-border-card)

  .react-flow__controls-button
    background: var(--roadmap-bg-elevated)
    border-bottom-color: var(--roadmap-border)

    &:hover
      background: var(--roadmap-tab-bg)

    svg
      fill: var(--roadmap-text-primary)

    &:disabled svg
      fill: var(--roadmap-text-muted)
      fill-opacity: 0.5

@media (max-width: 1100px)
  .roadmap-editor-body
    flex-direction: column
    overflow: auto

  .roadmap-canvas-panel
    width: 100%
    height: min(52vh, 520px)
    border-right: 0
    border-bottom: 1px solid #ececec

  .roadmap-editor-main
    min-height: 420px

  .roadmap-side-panel--edge
    width: 100%
    border-left: 0
    border-top: 1px solid #ececec

  .roadmap-toolbar
    align-items: flex-start
    flex-direction: column
