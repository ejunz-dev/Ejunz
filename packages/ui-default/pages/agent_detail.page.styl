// Agent detail: Work Rules Memory & shared blocks
.agent-detail__memory
  white-space: pre-wrap
  word-wrap: break-word
  margin: 0
  background: #f5f5f5
  color: #242424
  padding: 10px
  border-radius: 4px
  border: 1px solid #e0e0e0
  font-family: inherit
  font-size: rem(13px)
  line-height: 1.5

.theme--dark
  .agent-detail__memory
    background: #1e1f21
    color: #e8e8e8
    border: 1px solid rgba(255, 255, 255, 0.12)
