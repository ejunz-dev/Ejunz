.page--base_create,
.page--base_edit
  .base-form-page
    &__intro
      margin: rem(4px 0 0)

    &__form
      .form__item:last-child
        margin-bottom: 0

    &__actions
      display: flex
      flex-direction: column
      align-items: stretch
      gap: rem(10px)
      padding: rem($section-gap-v) rem($section-gap-h)

      .button
        white-space: nowrap
        width: 100%
        margin-bottom: 0

    &__actions-panel
      .section__body
        padding-top: rem($section-gap-v)
        padding-bottom: rem($section-gap-v)

    &__sidebar
      +above(rupture.mobile-cutoff)
        position: sticky
        top: rem($section-margin)

  .section--base-categories
    .section__header
      padding-bottom: rem(4px)

      .section__title
        font-size: 1.1rem
        margin-bottom: rem(4px)

      .typo.supplementary
        margin: 0
        font-size: rem($font-size-small)

    &__body
      padding-top: rem(8px)

  .widget--category-filter--sidebar
    display: flex
    flex-direction: column
    gap: rem(6px)
    margin: 0

    .widget--category-filter__category
      width: 100%
      margin: 0
      padding: 0

    .widget--category-filter__tag
      display: inline-block
      width: 100%
      box-sizing: border-box
      border-radius: rem(4px)
      cursor: pointer
      transition: background .15s ease, color .15s ease

    .widget--category-filter__drop
      width: rem(220px)

    .widget--category-filter__subcategory
      display: inline-block
      margin: rem(2px)
