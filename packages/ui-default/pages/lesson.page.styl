/* CSS variables at :root so portal components can inherit them */
html
  --lesson-bg-page: #fafafa
  --lesson-bg-card: #ffffff
  --lesson-bg-secondary: #f5f5f5
  --lesson-bg-hover: #f3f4f6
  --lesson-text-primary: #111111
  --lesson-text-secondary: #666666
  --lesson-text-tertiary: #999999
  --lesson-text-body: #333333
  --lesson-border: #ececec
  --lesson-border-card: #e8e8e8
  --lesson-border-input: #d8d8d8
  --lesson-primary: #ffeb3b
  --lesson-primary-border: #e6c200
  --lesson-white-on-primary: #111111
  --lesson-accent: #2b78e4
  --lesson-accent-muted-bg: rgba(43, 120, 228, 0.10)
  --lesson-accent-muted-fg: #2b78e4
  --lesson-success: #4caf50
  --lesson-success-bg: #e8f5e9
  --lesson-danger: #f44336
  --lesson-danger-bg: #ffebee
  --lesson-orange: #ff9800
  --lesson-orange-muted-bg: rgba(255, 152, 0, 0.10)
  --lesson-review-bg: #fff3e0
  --lesson-review-fg: #e65100
  --lesson-done-bg: #e8f5e9
  --lesson-done-fg: #2e7d32
  --lesson-white-on-accent: #ffffff
  --lesson-modal-shadow: 0 4px 20px rgba(0, 0, 0, 0.15)
  --lesson-drawer-scrim: rgba(0, 0, 0, 0.42)
  --lesson-drawer-shadow: 2px 0 8px rgba(0, 0, 0, 0.15)
  --lesson-drawer-shadow-right: -2px 0 8px rgba(0, 0, 0, 0.15)
  --lesson-backdrop: rgba(0, 0, 0, 0.42)

html.theme--dark
  --lesson-bg-page: #1e1e1e
  --lesson-bg-card: #2d2d2d
  --lesson-bg-secondary: #262729
  --lesson-bg-hover: #3a3b3d
  --lesson-text-primary: #e8e8e8
  --lesson-text-secondary: #bdbdbd
  --lesson-text-tertiary: #888888
  --lesson-text-body: #cccccc
  --lesson-border: #3c3c3c
  --lesson-border-card: #404040
  --lesson-border-input: #4a4a4a
  --lesson-primary: #ffeb3b
  --lesson-primary-border: #e6c200
  --lesson-white-on-primary: #111111
  --lesson-accent: #6eb3ff
  --lesson-accent-muted-bg: rgba(110, 179, 255, 0.18)
  --lesson-accent-muted-fg: #6eb3ff
  --lesson-success: #4ade80
  --lesson-success-bg: rgba(34, 197, 94, 0.16)
  --lesson-danger: #f44336
  --lesson-danger-bg: rgba(244, 67, 54, 0.16)
  --lesson-orange: #ff9800
  --lesson-orange-muted-bg: rgba(255, 152, 0, 0.16)
  --lesson-review-bg: rgba(251, 146, 60, 0.16)
  --lesson-review-fg: #fdba74
  --lesson-done-bg: rgba(34, 197, 94, 0.14)
  --lesson-done-fg: #4ade80
  --lesson-white-on-accent: #ffffff
  --lesson-modal-shadow: 0 4px 24px rgba(0, 0, 0, 0.55)
  --lesson-drawer-scrim: rgba(0, 0, 0, 0.58)
  --lesson-drawer-shadow: 2px 0 16px rgba(0, 0, 0, 0.5)
  --lesson-drawer-shadow-right: -2px 0 16px rgba(0, 0, 0, 0.5)
  --lesson-backdrop: rgba(0, 0, 0, 0.58)

.page--learn_lesson
  background: var(--lesson-bg-page)
  color: var(--lesson-text-primary)

  &.hasjs .nav
    position: relative !important
    top: auto
    left: auto

  .nav--shadow
    display: none

  .lesson-view-page
    position: relative
    top: auto
    left: auto
    right: auto
    bottom: auto
    z-index: auto
    flex: 1
    min-height: 0
    display: flex
    flex-direction: column
    max-width: none
    margin: 0
    padding: 0
    background: var(--lesson-bg-page)

.theme--dark.page--learn_lesson
  background: var(--lesson-bg-page)
